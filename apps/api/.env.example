# Typewriter Blog API — Environment Variables

# Server
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/typewriter_blog?sslmode=disable

# JWT
JWT_SECRET=change-me-to-a-strong-random-secret

# Admin seed (used on first run to create the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# S3-compatible storage (DigitalOcean Spaces, AWS S3, MinIO, etc.)
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_REGION=nyc3
S3_BUCKET=typewriter-blog
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
